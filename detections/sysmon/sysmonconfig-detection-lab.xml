<Sysmon schemaversion="4.90">
  <!--
    sysmonconfig-detection-lab.xml — a focused Sysmon baseline for the detection lab.

    Deliberately minimal: it turns on exactly the telemetry the Sigma rules in
    ../sigma depend on, so a fresh lab endpoint produces the events those rules
    match. It is NOT a production config — for that, start from Olaf Hartong's
    sysmon-modular or SwiftOnSecurity's config and tune. Cross-reference each
    block below to the rule it feeds.

    Apply:  sysmon -accepteula -i sysmonconfig-detection-lab.xml
    Update: sysmon -c sysmonconfig-detection-lab.xml
  -->
  <HashAlgorithms>SHA256</HashAlgorithms>
  <CheckRevocation>false</CheckRevocation>

  <EventFiltering>

    <!-- Event 1: ProcessCreate — feeds ntds_dump, potato_seimpersonate, wmiexec,
         rdp_hijack, scheduled_task (action), service-exec triage. Capture all;
         the Sigma rules carry the selectivity. Exclude only the noisiest signed
         updater to keep lab volume sane. -->
    <RuleGroup name="proc-create" groupRelation="or">
      <ProcessCreate onmatch="exclude">
        <Image condition="is">C:\Windows\System32\SearchIndexer.exe</Image>
      </ProcessCreate>
    </RuleGroup>

    <!-- Event 10: ProcessAccess — feeds lsass_handle_access. Captures ALL handle
         opens to LSASS (no GrantedAccess filter here on purpose: exact masks are
         brittle and vary, so collect broadly and let the lsass_handle_access Sigma
         rule apply the dump-shaped GrantedAccess masks downstream). The exclude
         group below drops the OS/AV processes that read LSASS normally. -->
    <RuleGroup name="lsass-access" groupRelation="or">
      <ProcessAccess onmatch="include">
        <TargetImage condition="image">lsass.exe</TargetImage>
      </ProcessAccess>
    </RuleGroup>
    <RuleGroup name="lsass-access-noise" groupRelation="or">
      <ProcessAccess onmatch="exclude">
        <SourceImage condition="image">MsMpEng.exe</SourceImage>
        <SourceImage condition="image">MsSense.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\wininit.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\csrss.exe</SourceImage>
      </ProcessAccess>
    </RuleGroup>

    <!-- Events 12/13: RegistryEvent — baseline coverage for autorun/WDigest
         persistence variants (Run keys, UseLogonCredential). Scoped to the
         high-signal keys so the lab is not flooded. -->
    <RuleGroup name="registry-autorun" groupRelation="or">
      <RegistryEvent onmatch="include">
        <TargetObject condition="contains">\CurrentVersion\Run</TargetObject>
        <TargetObject condition="contains">\SecurityProviders\WDigest\UseLogonCredential</TargetObject>
        <TargetObject condition="contains">\Image File Execution Options\</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <!-- Events 17/18: PipeEvent — corroborates potato_seimpersonate (spoolss/DCOM
         coercion pipes) and named-pipe lateral movement. -->
    <RuleGroup name="pipe-events" groupRelation="or">
      <PipeEvent onmatch="include">
        <PipeName condition="contains">spoolss</PipeName>
        <PipeName condition="contains">efsrpc</PipeName>
        <PipeName condition="contains">lsarpc</PipeName>
        <PipeName condition="contains">atsvc</PipeName>
        <PipeName condition="contains">svcctl</PipeName>
      </PipeEvent>
    </RuleGroup>

    <!-- Events 19/20/21: WmiEvent — feeds wmi_event_subscription_consumer. This is
         the whole reason a Run-key/scheduled-task baseline is not enough: WMI
         subscription persistence is fileless and only shows here.
         NOTE on Sysmon semantics: an EMPTY onmatch="exclude" group excludes
         nothing, i.e. it logs ALL WmiEvent (19/20/21) — which is what we want. (An
         empty onmatch="include" would do the opposite and log none.) -->
    <RuleGroup name="wmi-events" groupRelation="or">
      <WmiEvent onmatch="exclude" />
    </RuleGroup>

  </EventFiltering>
</Sysmon>
