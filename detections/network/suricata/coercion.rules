# coercion.rules — DCERPC authentication-coercion vectors (PetitPotam & friends).
#
# Network mirror of the 5145 named-pipe coercion detection in dotfiles-Kali's
# PURPLE-TEAM.md (htpx pair coerce-petitpotam <-> coercion-5145). Each coercion
# technique binds a specific MS RPC interface to force a target (ideally a DC) to
# authenticate to the attacker, who then relays it. Detect on the interface UUID
# (the dce_iface keyword matches the DCERPC bind over SMB/445 or TCP/135) — the
# interface is the invariant; the tool and opnum vary.
#
# sids are in a local/custom range (9_000_000+); renumber if it collides with your
# ruleset. These flag the *bind*, which has benign uses (real printing, EFS, DFS),
# so alert + investigate rather than drop. Validate by running the matching coerce
# from dotfiles-Kali (hacktheplanet "Coercion -> relay -> domain compromise" fold).

alert tcp any any -> $HOME_NET [445,135] (msg:"DOTFILES-DEFENSE Coercion MS-EFSRPC bind (PetitPotam)"; flow:to_server,established; dce_iface:c681d488-d850-11d0-8c52-00c04fd90f7e; classtype:attempted-recon; metadata:mitre_tactic_id TA0006, mitre_technique_id T1187; sid:9000001; rev:1;)

alert tcp any any -> $HOME_NET [445,135] (msg:"DOTFILES-DEFENSE Coercion MS-RPRN bind (PrinterBug/spooler)"; flow:to_server,established; dce_iface:12345678-1234-abcd-ef00-0123456789ab; classtype:attempted-recon; metadata:mitre_tactic_id TA0006, mitre_technique_id T1187; sid:9000002; rev:1;)

alert tcp any any -> $HOME_NET [445,135] (msg:"DOTFILES-DEFENSE Coercion MS-DFSNM bind (DFSCoerce)"; flow:to_server,established; dce_iface:4fc742e0-4a10-11cf-8273-00aa004ae673; classtype:attempted-recon; metadata:mitre_tactic_id TA0006, mitre_technique_id T1187; sid:9000003; rev:1;)

alert tcp any any -> $HOME_NET [445,135] (msg:"DOTFILES-DEFENSE Coercion MS-FSRVP bind (ShadowCoerce)"; flow:to_server,established; dce_iface:a8e0653c-2744-4389-a61d-7373df8b2292; classtype:attempted-recon; metadata:mitre_tactic_id TA0006, mitre_technique_id T1187; sid:9000004; rev:1;)
